        // No wallet exists, go to setup
        _navigateToScreen(const SetupScreen());
      }
    } catch (e) {
      if (!mounted) return;

      setState(() {
        _initMessage = 'Error: ${e.toString()}';
      });

      // Show error and navigate to setup after delay
      await Future.delayed(const Duration(milliseconds: 2000));
      if (mounted) {
        _navigateToScreen(const SetupScreen());
      }
    }
