                        : '• Community offering for ${_selectedCOLDToken!.symbol}\n'
                          '• Required: 1 C0LD burn + DAO vote\n'
                          '• Interest: ${_selectedCOLDToken!.interestRate}\n'
                          '• Powered by Fuego Mob',
                    style: TextStyle(
                      color: Colors.white70,
                      fontSize: 12,
                      height: 1.5,
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 16),
          ],

          // Action Buttons
          Row(
            children: [
              Expanded(
                child: ElevatedButton.icon(
                  onPressed: _isConnectingChain ? null : _connectChain,
                  icon: _isConnectingChain
                      ? const SizedBox(
                          width: 16,
                          height: 16,
                          child: CircularProgressIndicator(
                            strokeWidth: 2,
                            valueColor: AlwaysStoppedAnimation<Color>(Colors.white),
                          ),
                        )
                      : Icon(Icons.link, size: 18),
                  label: Text(_isChainConnected ? 'Refresh Balance' : 'Connect'),
                  style: ElevatedButton.styleFrom(
                    backgroundColor:
                        _isChainConnected ? const Color(0xFF4A90E2) : AppTheme.successColor,
                    foregroundColor: Colors.white,
                    padding: const EdgeInsets.symmetric(vertical: 12),
                    shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(8),
                    ),
                  ),
                ),
              ),
              const SizedBox(width: 8),
              Expanded(
                child: ElevatedButton.icon(
                  onPressed: _isWalletdRunning ? _stopWalletd : _startWalletd,
                  icon: Icon(
                    _isWalletdRunning ? Icons.stop : Icons.play_arrow,
                    size: 18,
                  ),
                  label: Text(_isWalletdRunning ? 'Stop walletd' : 'Start walletd'),
                  style: ElevatedButton.styleFrom(
                    backgroundColor:
                        _isWalletdRunning ? Colors.red : AppTheme.successColor,
                    foregroundColor: Colors.white,
                    padding: const EdgeInsets.symmetric(vertical: 12),
                    shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(8),
                    ),
                  ),
                ),
              ),
            ],
          ),

          const SizedBox(height: 8),

          // Advanced Actions
          Row(
            children: [
              Expanded(
                child: ElevatedButton.icon(
                  onPressed: _isChainConnected ? _transferCOLD : null,
                  icon: Icon(Icons.send, size: 18),
                  label: const Text('Transfer COLD'),
                  style: ElevatedButton.styleFrom(
                    backgroundColor: _isChainConnected ? Colors.orange : AppTheme.textMuted,
                    foregroundColor: Colors.white,
                    padding: const EdgeInsets.symmetric(vertical: 12),
                    shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(8),
                    ),
                  ),
                ),
              ),
              const SizedBox(width: 8),
              Expanded(
                child: ElevatedButton.icon(
                  onPressed: _isChainConnected ? _showBurnRequirements : null,
                  icon: Icon(Icons.how_to_vote, size: 18),
                  label: const text('DAO Listing'),
                  style: ElevatedButton.styleFrom(
                    backgroundColor: _isChainConnected ? Colors.blue : AppTheme.textMuted,
                    foregroundColor: Colors.white,
                    padding: const EdgeInsets.symmetric(vertical: 12),
                    shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(8),
                    ),
                  ),
                ),
              ),
            ],
          ),

          const SizedBox(height: 8),

          // Propose Token
          if (_isChainConnected)
            SizedBox(
              width: double.infinity,
              child: ElevatedButton.icon(
                onPressed: _proposeToken,
                icon: Icon(Icons.add_circle_outline, size: 18),
                label: const Text('Propose New Token'),
                style: ElevatedButton.styleFrom(
                  backgroundColor: Colors.purple[700],
                  foregroundColor: Colors.white,
                  padding: const EdgeInsets.symmetric(vertical: 12),
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(8),
                  ),
                ),
              ),
            ),

          const SizedBox(height: 16),

          // Service Logs
          if (_isWalletdRunning || _isChainConnected) ...[
            Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(
                color: AppTheme.backgroundColor,
                borderRadius: BorderRadius.circular(8),
                border: Border.all(color: AppTheme.dividerColor),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    'Activity Log',
                    style: TextStyle(
                      fontSize: 12,
                      fontWeight: FontWeight.bold,
                      color: AppTheme.textPrimary,
                    ),
                  ),
                  const SizedBox(height: 4),
                  Container(
                    height: 80,
                    child: SingleChildScrollView(
                      child: Text(
                        (_serviceLog.isNotEmpty ? _serviceLog : '') + (_web3Log.isNotEmpty ? _web3Log : ''),
                        style: TextStyle(
                          fontSize: 9,
                          fontFamily: 'monospace',
                          color: AppTheme.textMuted,
                          height: 1.2,
                        ),
                      ),
                    ),
                  ),
                ],
              ),
            ),
            const SizedBox(height: 16),
          ],

          // Proposed Tokens (if any exist)
          if (_isChainConnected) ...[
            FutureBuilder<List<ColdTokenInfo>>(
              future: Future.value(ColdTokenRepository.instance.getProposedTokens()),
              builder: (context, snapshot) {
                if (!snapshot.hasData || snapshot.data!.isEmpty) {
                  return const SizedBox.shrink();
                }
                return Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      'DAO Proposal Queue',
                      style: TextStyle(
                        fontSize: 16,
                        fontWeight: FontWeight.bold,
                        color: AppTheme.textPrimary,
                      ),
                    ),
                    const SizedBox(height: 8),
                    ...snapshot.data!.map((token) => _buildProposedTokenCard(token)),
                  ],
                );
              },
            ),
          ],

          const SizedBox(height: 24),

          // Official C0LD Info - Always Available
          Container(
            padding: const EdgeInsets.all(16),
            decoration: BoxDecoration(
              color: const Color(0xFF0A0E14).withOpacity(0.5),
              borderRadius: BorderRadius.circular(12),
              border: Border.all(color: Colors.blue[900]!),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Icon(Icons.warning_amber, color: Colors.blue[900], size: 20),
                    const SizedBox(width: 8),
                    Text(
                      'Official C0LD Offerings',
                      style: TextStyle(
                        fontSize: 14,
                        fontWeight: FontWeight.bold,
                        color: Colors.blue[900],
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                if (_selectedChain == Blockchain.ethereum) ...[
                  Text(
                    '• Contract: ${ColdTokenRepository.instance.getOfficialC0LD().contractAddress.substring(0, 25)}...\n'
                    '• Interest: 12.5% - 33% (paid in HEAT)\n'
                    '• Chain: Ethereum (Ξ) Mainnet\n'
                    '• Status: Active',
                    style: TextStyle(
                      color: Colors.grey[800]!.withOpacity(0.8),
                      fontSize: 12,
                      height: 1.4,
                    ),
                  ),
                ] else ...[
                  Text(
                    '• C0LD is an Ethereum ERC20 token\n'
                    '• Switch to Ethereum to view official C0LD\n'
                    '• Solana integration for C0LD: Future',
                    style: TextStyle(
                      color: Colors.grey[800]!.withOpacity(0.8),
                      fontSize: 12,
                      height: 1.4,
                    ),
                  ),
                ],
              ],
            ),
          ),

          const SizedBox(height: 16),

          // Future Roadmap
          Container(
            padding: const EdgeInsets.all(12),
            decoration: BoxDecoration(
              color: AppTheme.surfaceColor,
              borderRadius: BorderRadius.circular(8),
              border: Border.all(color: AppTheme.dividerColor),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Future COLD Offerings',
                  style: TextStyle(
                    fontSize: 12,
                    fontWeight: FontWeight.bold,
                    color: AppTheme.textSecondary,
                  ),
                ),
                const SizedBox(height: 4),
                Text(
                  'ZKsync Era • zkC0DL3 • Arbitrum • Polygon • Fuego-SOL',
                  style: TextStyle(
                    fontSize: 10,
                    color: AppTheme.textMuted,
                    fontStyle: FontStyle.italic,
                  ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  // 🎨 UI COMPONENTS --------------------------------------------------------

  Widget _buildChainButton(Blockchain chain, String label) {
    final isSelected = _selectedChain == chain;
    final isConnected = Web3MultiChainService.instance.isChainConnected(chain);

    return ActionChip(
      avatar: Icon(
        chain == Blockchain.ethereum ? Icons.currency_bitcoin : Icons.grain,
        color: isSelected ? Colors.white : ColdTokenPresentation.getChainColor(chain),
        size: 16,
      ),
      label: Text(label, style: TextStyle(color: isSelected ? Colors.white : null)),
      backgroundColor: isSelected
          ? ColdTokenPresentation.getChainColor(chain)
          : Colors.grey[200],
      onPressed: () => _switchChain(chain),
      side: BorderSide(
        color: isSelected
            ? ColdTokenPresentation.getChainColor(chain)
            : Colors.grey[400]!,
        width: isSelected ? 2.0 : 1.0,
      ),
    );
  }

  Widget _buildTokenCard(ColdTokenInfo token) {
    return Card(
      elevation: _selectedCOLDToken == token ? 4 : 2,
      shape: RoundedRectangleBorder(
        borderRadius: BorderRadius.circular(12),
        side: BorderSide(
          color: _selectedCOLDToken == token
              ? ColdTokenPresentation.getChainColor(token.chain)
              : AppTheme.dividerColor,
          width: _selectedCOLDToken == token ? 2.0 : 1.0,
        ),
      ),
      child: ListTile(
        leading: Container(
          padding: const EdgeInsets.all(8),
          decoration: BoxDecoration(
            color: ColdTokenPresentation.getChainColor(token.chain).withOpacity(0.1),
            borderRadius: BorderRadius.circular(8),
          ),
          child: Text(
            token.chainIcon,
            style: TextStyle(
              fontSize: 18,
              color: ColdTokenPresentation.getChainColor(token.chain),
              fontWeight: FontWeight.bold,
            ),
          ),
        ),
        title: Text(
          token.symbol,
          style: TextStyle(
            fontWeight: FontWeight.bold,
            color: AppTheme.textPrimary,
          ),
        ),
        subtitle: Text(
          token.name + (token.type == TokenType.official ? ' - OFFICIAL' : ''),
          style: TextStyle(
            fontSize: 12,
            color: token.isActive ? AppTheme.textSecondary : Colors.grey,
            fontWeight: token.type == TokenType.official ? FontWeight.w600 : FontWeight.normal,
          ),
        ),
        trailing: Text(
          token.interestRate,
          style: TextStyle(
            color: token.isActive ? Colors.green[700] : Colors.grey,
            fontWeight: FontWeight.w600,
            fontSize: 12,
          ),
        ),
        selected: _selectedCOLDToken == token,
        selectedTileColor: ColdTokenPresentation.getChainColor(token.chain).withOpacity(0.1),
        onTap: () {
          setState(() => _selectedCOLDToken = token);
          if (_isChainConnected) {
            _getBalance();
          }
        },
      ),
    );
  }

  Widget _buildProposedTokenCard(ColdTokenInfo token) {
    return Card(
      color: Colors.grey[300],
      shape: RoundedRectangleBorder(
        borderRadius: BorderRadius.circular(12),
        side: BorderSide(color: Colors.grey[400]!),
      ),
      child: ListTile(
        leading: const Icon(Icons.how_to_vote, color: Colors.blue),
        title: Text(
          token.symbol,
          style: const TextStyle(
            fontWeight: FontWeight.bold,
            color: Colors.black87,
          ),
        ),
        subtitle: Text(
          'DAO Required • 1 C0LD Burn • ${token.interestRate}',
          style: TextStyle(
            fontSize: 11,
            color: Colors.grey[700],
          ),
        ),
        trailing: const Text(
          'PROPOSED',
          style: TextStyle(
            color: Colors.blue,
            fontWeight: FontWeight.bold,
            fontSize: 10,
          ),
        ),
        onTap: () => _showBurnRequirements(),
      ),
    );
  }

  Widget _buildWalletdIntegrationPanel() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppTheme.surfaceColor,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(color: AppTheme.dividerColor),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Icon(
                _isWalletdRunning ? Icons.check_circle : Icons.info_outline,
                color: _isWalletdRunning ? AppTheme.successColor : AppTheme.warningColor,
                size: 20,
              ),
              const SizedBox(width: 8),
              Text(
                'Walletd Integration',
                style: TextStyle(
                  fontSize: 14,
                  fontWeight: FontWeight.bold,
                  color: AppTheme.textPrimary,
                ),
              ),
              const Spacer(),
              Switch(
                value: _isWalletdRunning,
                onChanged: (value) {
                  if (value) {
                    _startWalletd();
                  } else {
                    _stopWalletd();
                  }
                },
                activeColor: AppTheme.successColor,
              ),
            ],
          ),
          const SizedBox(height: 8),
          Text(
            _isWalletdRunning
                ? 'Optimized for HEAT minting via integrated GUI'
                : 'Enable walletd for faster, integrated burn proofs',
            style: TextStyle(
              color: AppTheme.textSecondary,
              fontSize: 12,
              height: 1.4,
            ),
          ),
          const SizedBox(height: 8),
          _buildServiceIndicator('walletd', _isWalletdRunning),
          const SizedBox(height: 4),
          _buildServiceIndicator('optimizer', _isOptimizerRunning),
          const SizedBox(height: 4),
          _buildServiceIndicator('xfg-stark-cli', _isCliReady),
        ],
      ),
    );
  }

  Widget _buildWeb3ConnectionPanel() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppTheme.surfaceColor,
        borderRadius: BorderRadius.circular(12),
        border: Border.all(
          color: _isChainConnected
              ? AppTheme.successColor.withOpacity(0.4)
              : AppTheme.dividerColor,
          width: _isChainConnected ? 2.0 : 1.0,
        ),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Icon(
                Icons.link,
                color: _isChainConnected ? AppTheme.successColor : AppTheme.textMuted,
                size: 20,
              ),
              const SizedBox(width: 8),
              Text(
                '${ColdTokenPresentation.getChainDisplayName(_selectedChain)} Connection',
                style: TextStyle(
                  fontSize: 14,
                  fontWeight: FontWeight.bold,
                  color: AppTheme.textPrimary,
                ),
              ),
              const Spacer(),
              Container(
                padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                decoration: BoxDecoration(
                  color: _isChainConnected
                      ? AppTheme.successColor.withOpacity(0.2)
                      : AppTheme.textMuted.withOpacity(0.2),
                  borderRadius: BorderRadius.circular(6),
                ),
                child: Text(
                  _isChainConnected ? 'Connected' : 'Disconnected',
                  style: TextStyle(
                    color: _isChainConnected ? AppTheme.successColor : AppTheme.textMuted,
                    fontSize: 11,
                    fontWeight: FontWeight.w600,
                  ),
                ),
              ),
            ],
          ),
          const SizedBox(height: 12),
          TextField(
            decoration: InputDecoration(
              labelText: _selectedCOLDToken != null
                  ? '${_selectedCOLDToken!.symbol} Address'
                  : 'Address (0x... or Solana address)',
              hintText: _selectedChain == Blockchain.ethereum ? '0x...' : 'Solana address',
              prefixIcon: Icon(Icons.account_balance_wallet, size: 18),
              filled: true,
              fillColor: AppTheme.backgroundColor,
              border: OutlineInputBorder(
                borderRadius: BorderRadius.circular(8),
                borderSide: BorderSide(color: AppTheme.dividerColor),
              ),
            ),
            style: TextStyle(
              fontSize: 12,
              fontFamily: 'monospace',
            ),
            onChanged: (value) => setState(() => _coldAddress = value),
            onSubmitted: (_) => _connectChain(),
          ),
          if (Web3MultiChainService.instance.currentChain != _selectedChain) ...[
            const SizedBox(height: 8),
            Text(
              'Note: Service configured for ${ColdTokenRepository.instance.getOfficialC0LD().contractAddress.substring(0, 25)}...',
              style: TextStyle(
                fontSize: 10,
                color: AppTheme.textMuted,
                fontStyle: FontStyle.italic,
              ),
            ),
          ],
        ],
      ),
    );
  }

  Widget _buildBurnOptionCard({
    required String title,
    required String burnAmount,
    required String heatAmount,
    required String description,
    required bool isSelected,
    required VoidCallback onTap,
  }) {
    return GestureDetector(
      onTap: onTap,
      child: Container(
        padding: const EdgeInsets.all(16),
        decoration: BoxDecoration(
          color: isSelected ? AppTheme.primaryColor.withOpacity(0.1) : AppTheme.surfaceColor,
          borderRadius: BorderRadius.circular(12),
          border: Border.all(
            color: isSelected ? AppTheme.primaryColor : AppTheme.dividerColor,
            width: isSelected ? 2.0 : 1.0,
          ),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                Icon(
                  isSelected ? Icons.radio_button_checked : Icons.radio_button_unchecked,
                  color: isSelected ? AppTheme.primaryColor : AppTheme.textMuted,
                  size: 20,
                ),
                const SizedBox(width: 8),
                Text(
                  title,
                  style: TextStyle(
                    fontSize: 16,
                    fontWeight: FontWeight.bold,
                    color: AppTheme.textPrimary,
                  ),
                ),
              ],
            ),
            const SizedBox(height: 8),
            Text(
              '$burnAmount → Mint $heatAmount',
              style: TextStyle(
                fontSize: 14,
                fontWeight: FontWeight.w600,
                color: AppTheme.primaryColor,
              ),
            ),
            const SizedBox(height: 4),
            Text(
              description,
              style: TextStyle(
                fontSize: 12,
                color: AppTheme.textSecondary,
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildServiceIndicator(String service, bool isRunning) {
    return Row(
      mainAxisSize: MainAxisSize.min,
      children: [
        Container(
          width: 8,
          height: 8,
          decoration: BoxDecoration(
            color: isRunning ? AppTheme.successColor : AppTheme.textMuted,
            borderRadius: BorderRadius.circular(4),
          ),
        ),
        const SizedBox(width: 6),
        Text(
          service,
          style: TextStyle(
            fontSize: 11,
            color: isRunning ? AppTheme.textPrimary : AppTheme.textMuted,
            fontWeight: isRunning ? FontWeight.w600 : FontWeight.normal,
          ),
        ),
      ],
    );
  }

  Widget _buildCOLDTabOLD() {
    // Legacy template - useful if something breaks
    return const Center(
      child: Text('COLD Interest Lounge with Ethereum & Solana'),
    );
  }

  // 🔧 WALLETD CONTROL FUNCTIONS -------------------------------------------

  Future<void> _startWalletd() async {
    setState(() => _isWalletdRunning = true);
    final started = await WalletdService.instance.startWalletd(
      enableRpc: true,
      daemonAddress: 'localhost:8081',
    );
    if (!started && mounted) {
      _showSnackBar('Failed to start walletd', Colors.red);
      setState(() => _isWalletdRunning = false);
    }
  }

  Future<void> _stopWalletd() async {
    await WalletdService.instance.stopWalletd();
    setState(() => _isWalletdRunning = false);
  }

  Future<void> _startOptimizer() async {
    setState(() => _isOptimizerRunning = true);
    final started = await WalletdService.instance.startOptimizer(
      autoOptimize: true,
      scanInterval: 300,
    );
    if (!started && mounted) {
      _showSnackBar('Failed to start optimizer', Colors.red);
      setState(() => _isOptimizerRunning = false);
    }
  }

  Future<void> _stopOptimizer() async {
    await WalletdService.instance.stopOptimizer();
    setState(() => _isOptimizerRunning = false);
  }
}
