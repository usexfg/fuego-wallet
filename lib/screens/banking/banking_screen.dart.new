import 'dart:async';
import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:provider/provider.dart';
import 'package:flutter_screenutil/flutter_screenutil.dart';

import '../../services/cli_service.dart';
import '../../services/walletd_service.dart';
import '../../services/web3_multi_chain_service.dart';
import '../../config/cold_tokens_config.dart';
import '../../models/transaction_model.dart';
import '../../providers/wallet_provider.dart';
import '../../models/wallet.dart';
import '../../utils/theme.dart';
import 'burn_deposits_screen.dart';

/// Updated Banking Screen with Ξternal Flame (HEAT) and COLD Interest (Multi-Chain)
/// - ETH & Solana support for COLD
/// - Chain selector for COLD menu
/// - Official C0LD + Fuego Mob offerings
class BankingScreen extends StatefulWidget {
  const BankingScreen({super.key});
  @override
  State<BankingScreen> createState() => _BankingScreenState();
}

class _BankingScreenState extends State<BankingScreen>
    with SingleTickerProviderStateMixin {
  late TabController _tabController;

  // 🔥 Ξternal Flame Tab State
  String _selectedBurnOption = 'standard';
  bool _isBurning = false;

  // ❄️ COLD Tab State
  bool _isConnectingChain = false;
  bool _isChainConnected = false;
  Blockchain _selectedChain = Blockchain.ethereum;
  String _coldAddress = '';
  Map<String, dynamic>? _coldBalance;
  String _web3Log = '';

  // Walletd Integration State
  bool _isWalletdRunning = false;
  bool _isOptimizerRunning = false;
  bool _isCliReady = false;
  String _serviceLog = '';

  // COLD Token Selection
  ColdTokenInfo? _selectedCOLDToken;
  List<ColdTokenInfo> _availableTokens = [];

  @override
  void initState() {
    super.initState();
    _tabController = TabController(length: 2, vsync: this);
    _initializeServices();
    _checkCliAvailability();
  }

  @override
  void dispose() {
    _tabController.dispose();
    super.dispose();
  }

  /// Initialize all services
  Future<void> _initializeServices() async {
    // Walletd service
    await WalletdService.instance.initialize();
    WalletdService.instance.setWalletdLogCallback((log) {
      if (mounted) setState(() => _serviceLog = 'walletd: $log\n$_serviceLog');
    });
    WalletdService.instance.setOptimizerLogCallback((log) {
      if (mounted) setState(() => _serviceLog = 'optimizer: $log\n$_serviceLog');
    });
    WalletdService.instance.setStatusCallbacks(
      onWalletd: (running) => mounted ? setState(() => _isWalletdRunning = running) : null,
      onOptimizer: (running) => mounted ? setState(() => _isOptimizerRunning = running) : null,
    );

    // Multi-chain Web3 service
    await Web3MultiChainService.instance.initialize();
    Web3MultiChainService.instance.setLogCallback((log) {
      if (mounted) setState(() => _web3Log = '$log\n$_web3Log');
    });
    Web3MultiChainService.instance.setChainStatusCallback((connected) {
      if (mounted) setState(() => _isChainConnected = connected);
    });
    Web3MultiChainService.instance.setBalanceCallback((balance) {
      if (mounted) setState(() => _coldBalance = balance);
    });
  }

  /// Check CLI binary availability
  Future<void> _checkCliAvailability() async {
    try {
      final binaryPath = await _getCliBinaryPath();
      final file = File(binaryPath);
      if (await file.exists()) {
        setState(() => _isCliReady = true);
      }
    } catch (e) {
      setState(() => _isCliReady = false);
    }
  }

  Future<String> _getCliBinaryPath() async {
    final Directory appDir = await getApplicationSupportDirectory();
    final String binaryName = Platform.isWindows
        ? 'xfg-stark-cli.exe'
        : Platform.isMacOS
            ? 'xfg-stark-cli-macos'
            : 'xfg-stark-cli-linux';
    return path.join(appDir.path, 'bin', binaryName);
  }

  // 🔥 ΞTERNAL FLAME HEAT MINTING FUNCTIONS ---------------------------------

  Future<void> _burnXFG(String option) async {
    double burnAmount;
    String heatAmount;

    if (option == 'standard') {
      burnAmount = 0.8;
      heatAmount = '8 Million HEAT';
    } else {
      burnAmount = 800.0;
      heatAmount = '8 Billion HEAT';
    }

    setState(() => _isBurning = true);

    try {
      // Check for integrated walletd
      if (_isWalletdRunning) {
        _showInfoDialog(
          'Integrated Burn',
          'Using walletd integrated burn proof generation:\n\n'
          'Amount: $burnAmount XFG\n'
          'Mint: $heatAmount\n'
          'Destination: Ethereum L1 via Arbitrum L2',
        );
        await WalletdService.instance.optimizeWallet();
      } else if (_isCliReady) {
        _showInfoDialog(
          'CLI Burn',
          'Generating STARK proof via xfg-stark-cli:\n\n'
          'Amount: $burnAmount XFG\n'
          'Mint: $heatAmount\n'
          'Using: Local CLI generation',
        );
      } else {
        _showInfoDialog(
          'Burn Available',
          'Run scripts/ensure-binaries.sh to enable burn proofs:\n\n'
          'Standard: 0.8 XFG → 8 Million HEAT\n'
          'Large: 800 XFG → 8 Billion HEAT',
        );
        return;
      }

      await Navigator.push(
        context,
        MaterialPageRoute(builder: (context) => BurnDepositsScreen()),
      );

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Burn process initiated for $burnAmount XFG → $heatAmount'),
            backgroundColor: Colors.green,
          ),
        );
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Burn failed: $e'),
            backgroundColor: Colors.red,
          ),
        );
      }
    } finally {
      if (mounted) setState(() => _isBurning = false);
    }
  }

  // ❄️ COLD MULTI-CHAIN FUNCTIONS -------------------------------------------

  /// Connect to selected blockchain (ETH or SOL)
  Future<void> _connectChain() async {
    if (_coldAddress.isEmpty) {
      _showSnackBar('Please enter a valid address', Colors.orange);
      return;
    }

    if (_selectedChain == Blockchain.solana && !Web3MultiChainService.instance.isChainConnected(Blockchain.solana)) {
      _showSnackBar('Solana integration requires additional program. Using ETH fallback.', Colors.blue);
      return;
    }

    setState(() => _isConnectingChain = true);

    try {
      // Connect to the selected chain
      final connected = await Web3MultiChainService.instance.connectChain(_selectedChain);

      if (!connected) {
        _showSnackBar('Failed to connect to ${ColdTokenPresentation.getChainDisplayName(_selectedChain)}', Colors.red);
        setState(() => _isConnectingChain = false);
        return;
      }

      // Load available tokens for this chain
      await _loadAvailableTokens();

      // Get balance for selected token
      if (_selectedCOLDToken != null) {
        await _getBalance();
      }

      _showSnackBar('Connected to ${ColdTokenPresentation.getChainDisplayName(_selectedChain)}', Colors.green);

    } catch (e) {
      _showSnackBar('Connection error: $e', Colors.red);
    } finally {
      if (mounted) setState(() => _isConnectingChain = false);
    }
  }

  /// Load available tokens for current chain
  Future<void> _loadAvailableTokens() async {
    final tokens = ColdTokenRepository.instance.getActiveTokens(_selectedChain, includeOfficial: true);

    if (mounted) {
      setState(() {
        _availableTokens = tokens;
        if (tokens.isNotEmpty) {
          _selectedCOLDToken ??= tokens.first;
        }
      });
    }
  }

  /// Get COLD token balance
  Future<void> _getBalance() async {
    if (_coldAddress.isEmpty || _selectedCOLDToken == null) return;

    if (!Web3MultiChainService.instance.isChainConnected(_selectedChain)) {
      _showSnackBar('Not connected to chain', Colors.red);
      return;
    }

    setState(() => _isConnectingChain = true);

    try {
      final balance = await Web3MultiChainService.instance.getBalance(
        address: _coldAddress,
        chain: _selectedChain,
        tokenContract: _selectedCOLDToken!.contractAddress,
      );

      if (balance != null) {
        _showSnackBar('Balance refreshed: ${balance['balance']} ${balance['symbol']}', Colors.green);
      } else {
        _showSnackBar('Failed to get balance', Colors.red);
      }
    } catch (e) {
      _showSnackBar('Balance error: $e', Colors.red);
    } finally {
      if (mounted) setState(() => _isConnectingChain = false);
    }
  }

  /// Transfer COLD tokens (Sends to DAO for listing)
  Future<void> _transferCOLD() async {
    if (_coldAddress.isEmpty || _selectedCOLDToken == null) {
      _showSnackBar('Select token and enter address', Colors.orange);
      return;
    }

    // Show transfer dialog
    final amountController = TextEditingController();
    final recipientController = TextEditingController();
    final keyController = TextEditingController();

    _showTransferDialog(amountController, recipientController, keyController);
  }

  void _showTransferDialog(
    TextEditingController amount,
    TextEditingController recipient,
    TextEditingController key,
  ) {
    showDialog(
      context: context,
      builder: (context) => StatefulBuilder(
        builder: (context, setState) {
          return AlertDialog(
            title: Text('Transfer ${_selectedCOLDToken?.symbol}'),
            content: SingleChildScrollView(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  TextField(
                    controller: amount,
                    decoration: const InputDecoration(labelText: 'Amount'),
                    keyboardType: TextInputType.number,
                  ),
                  TextField(
                    controller: recipient,
                    decoration: const InputDecoration(labelText: 'Recipient Address (0x...)'),
                  ),
                  TextField(
                    controller: key,
                    decoration: const InputDecoration(
                      labelText: 'Private Key',
                      hintText: '0x...',
                    ),
                    obscureText: true,
                  ),
                  const SizedBox(height: 8),
                  if (_selectedCOLDToken?.requiresDaoVote == true) ...[
                    Container(
                      padding: const EdgeInsets.all(8),
                      color: Colors.blue.withOpacity(0.1),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          Text(
                            '⚠️ DAO Listing Transfer',
                            style: TextStyle(
                              color: Colors.blue[900],
                              fontWeight: FontWeight.bold,
                            ),
                          ),
                          const SizedBox(height: 4),
                          Text(
                            'This transfer requires:\n'
                            '1. 1 C0LD burn to Fuego DAO\n'
                            '2. Fuego Mob vote (51%+)\n'
                            '3. Token added to COLD offerings',
                            style: TextStyle(
                              color: Colors.blue[800],
                              fontSize: 11,
                            ),
                          ),
                        ],
                      ),
                    ),
                  ],
                ],
              ),
            ),
            actions: [
              TextButton(
                onPressed: () => Navigator.of(context).pop(),
                child: const Text('Cancel'),
              ),
              ElevatedButton(
                onPressed: () async {
                  Navigator.of(context).pop();
                  await _performTransfer(amount.text, recipient.text, key.text);
                },
                child: const Text('Send'),
              ),
            ],
          );
        },
      ),
    );
  }

  Future<void> _performTransfer(String amount, String recipient, String privateKey) async {
    if (amount.isEmpty || recipient.isEmpty || privateKey.isEmpty) {
      _showSnackBar('All fields required', Colors.red);
      return;
    }

    setState(() => _isConnectingChain = true);

    try {
      final result = await Web3MultiChainService.instance.transfer(
        fromAddress: _coldAddress,
        toAddress: recipient,
        amount: amount,
        recipient: recipient,
        chain: _selectedChain,
        tokenContract: _selectedCOLDToken!.contractAddress,
        privateKey: privateKey,
      );

      if (result != null && result['success'] == true) {
        _showSnackBar(
          'Transfer sent: ${result['txHash']}\n'
          'View on ${_selectedChain == Blockchain.ethereum ? 'Etherscan' : 'Solana Explorer'}',
          Colors.green,
        );
        onLog('Transfer: ${result['txHash']}');
      } else {
        _showSnackBar('Transfer failed or pending', Colors.red);
      }
    } catch (e) {
      _showSnackBar('Transfer error: $e', Colors.red);
    } finally {
      if (mounted) setState(() => _isConnectingChain = false);
    }
  }

  /// Switch blockchain (ETH ↔ SOL)
  Future<void> _switchChain(Blockchain newChain) async {
    if (_selectedChain == newChain) return;

    setState(() {
      _selectedChain = newChain;
      _coldBalance = null;
      _availableTokens = [];
      _selectedCOLDToken = null;
    });

    _showSnackBar(
      'Switched to ${ColdTokenPresentation.getChainDisplayName(newChain)}',
      Colors.blue,
    );

    // Auto-connect if previously connected
    if (Web3MultiChainService.instance.isChainConnected(newChain)) {
      await _loadAvailableTokens();
    }
  }

  /// Propose new token for DAO listing
  Future<void> _proposeToken() async {
    final nameController = TextEditingController();
    final symbolController = TextEditingController();
    final contractController = TextEditingController();
    final rateController = TextEditingController();
    final descController = TextEditingController();
    final docController = TextEditingController();

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('Propose new Fuego Mob Token'),
        content: SingleChildScrollView(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              Text(
                'Requirements:\n'
                '• DAO vote by Fuego Mob\n'
                '• Burn 1 full C0LD token\n'
                '• Minimum 51% approval\n',
                style: TextStyle(
                  color: Colors.blue[900],
                  fontWeight: FontWeight.bold,
                ),
              ),
              const SizedBox(height: 8),
              TextField(controller: nameController, decoration: const InputDecoration(labelText: 'Token Name')),
              TextField(controller: symbolController, decoration: const InputDecoration(labelText: 'Symbol')),
              TextField(controller: contractController, decoration: const InputDecoration(labelText: 'Contract Address')),
              TextField(controller: rateController, decoration: const InputDecoration(labelText: 'Interest Rate (e.g., 15%)')),
              TextField(controller: descController, decoration: const InputDecoration(labelText: 'Description')),
              TextField(controller: docController, decoration: const InputDecoration(labelText: 'Documentation URL')),
            ],
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Cancel'),
          ),
          ElevatedButton(
            onPressed: () async {
              Navigator.of(context).pop();
              final result = await ColdTokenRepository.instance.proposeToken(
                name: nameController.text,
                symbol: symbolController.text,
                contractAddress: contractController.text,
                chain: _selectedChain,
                interestRate: rateController.text,
                description: descController.text,
                documentation: docController.text,
              );
              _showSnackBar(result, Colors.blue);
            },
            child: const Text('Submit to DAO'),
          ),
        ],
      ),
    );
  }

  /// Show C0LD burn requirements for listing
  void _showBurnRequirements() {
    final token = _selectedCOLDToken;
    if (token == null) return;

    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('C0LD Burn Requirements'),
        content: Text(
          'To list ${token.symbol} on Fuego Mob:\n\n'
          '1. Burn 1 C0LD token via Ξternal Flame menu\n'
          '2. Generate STARK proof\n'
          '3. Submit proof to Fuego DAO\n'
          '4. Fuego Mob votes (51%+)\n'
          '5. Token activated after approval\n\n'
          'Current Status: ${token.isActive ? "Active" : "Proposed"}\n'
          'DAO Required: ${token.requiresDaoVote ? "Yes" : "No"}',
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('Close'),
          ),
          TextButton(
            onPressed: () {
              Navigator.of(context).pop();
              _burnXFG('standard'); // Burn for listing
            },
            child: const Text('Burn 1 C0LD'),
          ),
        ],
      ),
    );
  }

  // ✅ HELPER FUNCTIONS ------------------------------------------------------

  void _showInfoDialog(String title, String content) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(title),
        content: Text(content),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: const Text('OK'),
          ),
        ],
      ),
    );
  }

  void _showSnackBar(String message, Color color) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: color,
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20)),
        margin: const EdgeInsets.all(16),
      ),
    );
  }

  void onLog(String message) {
    setState(() => _web3Log = '$message\n$_web3Log');
  }

  // 🎨 UI BUILDERS ----------------------------------------------------------

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Banking'),
        bottom: TabBar(
          controller: _tabController,
          indicatorColor: AppTheme.primaryColor,
          labelColor: AppTheme.primaryColor,
          unselectedLabelColor: AppTheme.textSecondary,
          tabs: const [
            Tab(text: 'Ξternal Flame'),
            Tab(text: 'COLD'),
          ],
        ),
      ),
      body: TabBarView(
        controller: _tabController,
        children: [
          _buildEternalFlameTab(),
          _buildCOLDTab(),
        ],
      ),
    );
  }

  // 🔥 ΞTERNAL FLAME TAB ----------------------------------------------------

  Widget _buildEternalFlameTab() {
    return SingleChildScrollView(
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          // Header
          Container(
            padding: const EdgeInsets.all(20),
            decoration: BoxDecoration(
              gradient: AppTheme.primaryGradient,
              borderRadius: BorderRadius.circular(16),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Icon(Icons.local_fire_department, color: Colors.white, size: 32),
                    const SizedBox(width: 12),
                    Text(
                      'Ξternal Flame',
                      style: TextStyle(
                        fontSize: 24,
                        fontWeight: FontWeight.bold,
                        color: Colors.white,
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                Text(
                  'Burn XFG to mint Fuego Ξmbers (HEAT)',
                  style: TextStyle(
                    fontSize: 16,
                    color: Colors.white.withOpacity(0.9),
                  ),
                ),
              ],
            ),
          ),

          const SizedBox(height: 20),

          // Walletd integration
          _buildWalletdIntegrationPanel(),

          const SizedBox(height: 16),

          // Burn options
          Text(
            'Select Burn Amount',
            style: TextStyle(
              fontSize: 18,
              fontWeight: FontWeight.bold,
              color: AppTheme.textPrimary,
            ),
          ),
          const SizedBox(height: 8),

          _buildBurnOptionCard(
            title: 'Standard Burn',
            burnAmount: '0.8 XFG',
            heatAmount: '8 Million HEAT',
            description: 'Standard burn for C0DL3 gas fees',
            isSelected: _selectedBurnOption == 'standard',
            onTap: () => setState(() => _selectedBurnOption = 'standard'),
          ),

          const SizedBox(height: 8),

          _buildBurnOptionCard(
            title: 'Large Burn',
            burnAmount: '800 XFG',
            heatAmount: '8 Billion HEAT',
            description: 'Large HEAT mint for privacy',
            isSelected: _selectedBurnOption == 'large',
            onTap: () => setState(() => _selectedBurnOption = 'large'),
          ),

          const SizedBox(height: 20),

          // Burn action
          SizedBox(
            width: double.infinity,
            child: ElevatedButton.icon(
              onPressed: _isBurning ? null : () => _burnXFG(_selectedBurnOption),
              icon: _isBurning
                  ? const SizedBox(
                      width: 20,
                      height: 20,
                      child: CircularProgressIndicator(
                        strokeWidth: 2,
                        valueColor: AlwaysStoppedAnimation<Color>(Colors.white),
                      ),
                    )
                  : const Icon(Icons.local_fire_department),
              label: Text(
                _isBurning
                  ? 'Processing Burn...'
                  : _selectedBurnOption == 'standard'
                      ? 'Burn 0.8 XFG & Mint HEAT'
                      : 'Burn 800 XFG & Mint HEAT',
                style: const TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
              ),
              style: ElevatedButton.styleFrom(
                backgroundColor: AppTheme.errorColor,
                foregroundColor: Colors.white,
                padding: const EdgeInsets.symmetric(vertical: 16),
                shape: RoundedRectangleBorder(
                  borderRadius: BorderRadius.circular(12),
                ),
              ),
            ),
          ),

          const SizedBox(height: 16),

          // Info card
          Container(
            padding: const EdgeInsets.all(16),
            decoration: BoxDecoration(
              color: AppTheme.surfaceColor,
              borderRadius: BorderRadius.circular(12),
              border: Border.all(color: AppTheme.dividerColor),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'About Ξternal Flame (HEAT)',
                  style: TextStyle(
                    fontSize: 14,
                    fontWeight: FontWeight.bold,
                    color: AppTheme.textPrimary,
                  ),
                ),
                const SizedBox(height: 8),
                Text(
                  'Fuego Ξmbers (HEAT) are atomic equivalent ERC20 tokens of XFG, '
                  'minted on Ethereum L1 using Arbitrum L2 for gas-efficiency. '
                  'HEAT functions as the gas token of Fuego\'s C0DL3 rollup.',
                  style: TextStyle(
                    color: AppTheme.textSecondary,
                    height: 1.4,
                    fontSize: 12,
                  ),
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  // ❄️ COLD TAB (Multi-Chain) ----------------------------------------------

  Widget _buildCOLDTab() {
    return SingleChildScrollView(
      padding: const EdgeInsets.all(16),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          // Header
          Container(
            padding: const EdgeInsets.all(20),
            decoration: BoxDecoration(
              gradient: ColdTokenPresentation.getChainColor(_selectedChain) == const Color(0xFF627EEA)
                  ? const LinearGradient(
                      colors: [Color(0xFF4A90E2), Color(0xFF2D5F8D)],
                      begin: Alignment.topLeft,
                      end: Alignment.bottomRight,
                    )
                  : const LinearGradient(
                      colors: [Color(0xFF9945FF), Color(0xFF5E1A9F)],
                      begin: Alignment.topLeft,
                      end: Alignment.bottomRight,
                    ),
              borderRadius: BorderRadius.circular(16),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Row(
                  children: [
                    Icon(Icons.savings, color: Colors.white, size: 32),
                    const SizedBox(width: 12),
                    Text(
                      'COLD Interest Lounge',
                      style: TextStyle(
                        fontSize: 22,
                        fontWeight: FontWeight.bold,
                        color: Colors.white,
                      ),
                    ),
                  ],
                ),
                const SizedBox(height: 8),
                Text(
                  '${ColdTokenPresentation.getChainDisplayName(_selectedChain)} • C0DL3 Interest',                  style: TextStyle(
                    fontSize: 14,
                    color: Colors.white.withOpacity(0.9),
                  ),
                ),
              ],
            ),
          ),

          const SizedBox(height: 20),

          // Chain Selector
          Container(
            padding: const EdgeInsets.all(16),
            decoration: BoxDecoration(
              color: AppTheme.surfaceColor,
              borderRadius: BorderRadius.circular(12),
              border: Border.all(color: AppTheme.dividerColor),
            ),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                Text(
                  'Blockchain',
                  style: TextStyle(
                    fontSize: 14,
                    fontWeight: FontWeight.bold,
                    color: AppTheme.textPrimary,
                  ),
                ),
                const SizedBox(height: 8),
                Wrap(
                  spacing: 8,
                  runSpacing: 8,
                  children: [
                    _buildChainButton(Blockchain.ethereum, 'Ξ Ethereum'),
                    _buildChainButton(Blockchain.solana, '◎ Solana'),
                    // Future chains can be added here:
                    // _buildChainButton(Blockchain.zksync_era, '⚡ ZKsync Era'),
                    // _buildChainButton(Blockchain.zk_c0dl3, '❄️ zkC0DL3'),
                  ],
                ),
              ],
            ),
          ),

          const SizedBox(height: 16),

          // Web3 Connection Panel
          _buildWeb3ConnectionPanel(),

          const SizedBox(height: 16),

          // Token Selection (only if connected)
          if (_isChainConnected && _availableTokens.isNotEmpty) ...[
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: AppTheme.surfaceColor,
                borderRadius: BorderRadius.circular(12),
                border: Border.all(color: AppTheme.dividerColor),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    'Select COLD Token',
                    style: TextStyle(
                      fontSize: 16,
                      fontWeight: FontWeight.bold,
                      color: AppTheme.textPrimary,
                    ),
                  ),
                  const SizedBox(height: 8),
                  if (_availableTokens.length == 1) ...[
                    _buildTokenCard(_availableTokens.first),
                  ] else ...[
                    ..._availableTokens.map((token) => _buildTokenCard(token)),
                  ],
                ],
              ),
            ),
            const SizedBox(height: 16),
          ],

          // Balance Display
          if (_coldBalance != null && _selectedCOLDToken != null) ...[
            Container(
              padding: const EdgeInsets.all(16),
              decoration: BoxDecoration(
                color: AppTheme.surfaceColor,
                borderRadius: BorderRadius.circular(12),
                border: Border.all(
                  color: _isChainConnected
                      ? AppTheme.successColor.withOpacity(0.3)
                      : AppTheme.dividerColor,
                ),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Row(
                    mainAxisAlignment: MainAxisAlignment.spaceBetween,
                    children: [
                      Text(
                        '${_selectedCOLDToken!.symbol} Balance',
                        style: TextStyle(
                          fontSize: 16,
                          fontWeight: FontWeight.bold,
                          color: AppTheme.textPrimary,
                        ),
                      ),
                      IconButton(
                        icon: Icon(Icons.refresh, color: AppTheme.primaryColor, size: 20),
                        onPressed: _isConnectingChain ? null : _getBalance,
                      ),
                    ],
                  ),
                  const SizedBox(height: 8),
                  Row(
                    mainAxisAlignment: MainAxisAlignment.spaceBetween,
                    children: [
                      Text(
                        '${_coldBalance!['balance']} ${_coldBalance!['symbol']}',
                        style: TextStyle(
                          fontSize: 24,
                          fontWeight: FontWeight.bold,
                          color: AppTheme.primaryColor,
                        ),
                      ),
                      if (_coldBalance!['interestRate'] != null)
                        Text(
                          _coldBalance!['interestRate'],
