      return binaryFile.path;
    } catch (e) {
      debugPrint('Failed to extract walletd binary: $e');

      // If we can't extract the binary, try to find system installed version
      final systemBinary = await _findSystemWalletd();
      if (systemBinary != null) {
        return systemBinary;
      }

      rethrow;
    }
