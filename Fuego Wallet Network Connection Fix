              mnemonic: '', // Empty mnemonic indicates existing wallet
              isRestore: true, // Indicates this is for an existing wallet
            ),
          ),
          (route) => false,
        );
      }
    } catch (e) {
      if (mounted) {
        setState(() {
          _errorMessage = 'Failed to open wallet: $e';
          _isLoading = false;
        });
      }
    }
  }

